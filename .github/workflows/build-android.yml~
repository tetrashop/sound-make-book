- name: Upload APK as artifact
  uses: actions/upload-artifact@v4
  with:
    name: sound-make-book-android
    path: android-app/app/build/outputs/apk/release/app-release.apk

- name: Create Release using GitHub CLI
  if: startsWith(github.ref, 'refs/tags/')
  env:
    GH_TOKEN: ${{ github.token }}
  run: |
    echo "Creating release for tag: ${{ github.ref_name }}"
    gh release create ${{ github.ref_name }} \
      --title "sound-make-book ${{ github.ref_name }}" \
      --notes-file android_release_notes.md \
      android-app/app/build/outputs/apk/release/app-release.apk || echo "Release creation failed but continuing"
